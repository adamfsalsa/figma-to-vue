{
  "name": "figma-to-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-assisted Figma to Vue 3 TypeScript pipeline case study for an accessible Trek-inspired finder.",
  "scripts": {
    "dev": "vite",
    "build": "npm run test:api-runtime && vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:api-runtime": "tsc -p tsconfig.api.json && node scripts/check-api-runtime.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "axe-core": "^4.9.1",
    "jsdom": "^24.1.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^2.0.19"
  }
}
