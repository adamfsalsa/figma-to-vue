# Environment variables for the optional AI analysis tier (api/analyze.ts).
# Set these in the Vercel project settings (Project → Settings → Environment
# Variables), NOT in a committed file. The app runs fully on the free local
# analyzer when these are absent — the AI endpoint just returns not_configured.
#
# Copy to .env for local reference only (.env is gitignored). Vercel does not
# read this file; it reads the dashboard values.

# Anthropic API key for the claude-sonnet-4-6 vision and content call.
# Load only a small prepaid balance on this key with auto-reload OFF — that is
# the hard spend ceiling. See docs/ai-analysis.md.
ANTHROPIC_API_KEY=

# Upstash Redis REST credentials for durable rate limiting. Without both, the
# endpoint refuses to call the billable model (fails to not_configured).
# Create a database at https://console.upstash.com and copy its REST URL+token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
