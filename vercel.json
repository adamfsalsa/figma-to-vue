{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/"
    }
  ],
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 60
    },
    "api/figma.ts": {
      "maxDuration": 30
    }
  }
}
